                    <Property Name="OpeningTimeMs" Category="ValveCalibration" />
                    <Property Name="Repeats" Category="ValveCalibration" />
                  </Expression>
                  <Expression xsi:type="rx:SelectMany">
                    <Name>LoopValve</Name>
