                          <PropertyMappings>
                            <Property Name="Enabled" />
                          </PropertyMappings>
                        </Expression>
                        <Expression xsi:type="SubscribeSubject">
                          <Name>CalibratingLoadCells</Name>
                        </Expression>
                        <Expression xsi:type="scr:ExpressionTransform">
